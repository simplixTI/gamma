# Copie este arquivo para android/keystore.properties e preencha com seus dados.
# NUNCA commitar o keystore.properties real nem o arquivo .keystore — adicione ao .gitignore.
#
# Para gerar a keystore (uma vez so, GUARDE o arquivo em local seguro):
#   keytool -genkey -v -keystore gamma-release.keystore \
#       -alias gamma -keyalg RSA -keysize 2048 -validity 10000
#
# Coloque o arquivo gamma-release.keystore em android/ (ou caminho absoluto).
# Se perder a keystore voce NAO podera publicar updates do app na Play Store.

storeFile=gamma-release.keystore
storePassword=SUA_SENHA_DA_KEYSTORE
keyAlias=gamma
keyPassword=SUA_SENHA_DA_CHAVE
